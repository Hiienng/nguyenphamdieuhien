# Database
DATABASE_URL=postgresql://user:pass@host/dbname
ETSY_MARKET_DB=postgresql://user:pass@host/market_dbname

# Claude / Anthropic
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# AI Vision — Gemini (2 dedicated keys, one per pipeline)
GEMINI_API_KEY_paid_imagereport=   # internal_extractor: Etsy Ads screenshot OCR
GEMINI_API_KEY_paid_thumbnail=     # vision_service: thumbnail evaluation & knowledge gen
GEMINI_MODEL=gemini-2.5-flash-lite
HUGGINGFACE_API_KEY=
HF_MODEL=zai-org/GLM-4.5V

# ImageKit
IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_PRIVATE_KEY=
IMAGEKIT_URL_ENDPOINT=
IMAGEKIT_FOLDER=/listing/EtseeMate

# JWT Auth
JWT_SECRET_KEY=change-me-to-random-secret-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MIN=30
JWT_REFRESH_EXPIRE_DAYS=7

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_SUBSCRIPTION=price_xxx   # recurring $9.9/month
STRIPE_PRICE_CREDIT_DEPOSIT=price_xxx # one-time $9.9 = 10 credits

# App
APP_ENV=development
SECRET_KEY=change-me
ALLOWED_ORIGINS=http://localhost:8000,https://nguyenphamdieuhien.online
